<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= apartment.title %> - Andrew Apartments</title>
  
  <!-- SEO Meta Tags -->
  <meta name="description" content="<%= seoData.description %>">
  <meta name="keywords" content="<%= seoData.keywords %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= seoData.canonical %>">
  
  <!-- Open Graph Tags for Social Media -->
  <meta property="og:title" content="<%= seoData.openGraph['og:title'] %>">
  <meta property="og:description" content="<%= seoData.openGraph['og:description'] %>">
  <meta property="og:image" content="<%= seoData.openGraph['og:image'] %>">
  <meta property="og:url" content="<%= seoData.openGraph['og:url'] %>">
  <meta property="og:type" content="<%= seoData.openGraph['og:type'] %>">
  <meta property="og:site_name" content="<%= seoData.openGraph['og:site_name'] %>">
  <meta property="og:locale" content="<%= seoData.openGraph['og:locale'] %>">
  
  <!-- Twitter Card Tags -->
  <meta name="twitter:card" content="<%= seoData.twitterCard['twitter:card'] %>">
  <meta name="twitter:title" content="<%= seoData.twitterCard['twitter:title'] %>">
  <meta name="twitter:description" content="<%= seoData.twitterCard['twitter:description'] %>">
  <meta name="twitter:image" content="<%= seoData.twitterCard['twitter:image'] %>">
  <meta name="twitter:creator" content="<%= seoData.twitterCard['twitter:creator'] %>">
  
  <!-- Schema.org JSON-LD for Rich Snippets -->
  <script type="application/ld+json">
    <%- JSON.stringify(seoData.schema) %>
  </script>
  
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-container">
      <div class="logo">
        <a href="/">🏠 ANDREW APARTMENTS</a>
      </div>
      <div class="search-bar">
        <form action="/search" method="GET">
          <input type="text" name="q" placeholder="Search apartments...">
          <select name="category">
            <option value="">All Categories</option>
            <option value="Rent">Rent</option>
            <option value="Serviced">Serviced</option>
            <option value="Sales">Sales</option>
          </select>
          <button type="submit">🔍 Search</button>
        </form>
      </div>
      <nav class="nav-menu">
        <a href="/rent" class="nav-link">🏠 Rent</a>
        <a href="/serviced" class="nav-link">⭐ Serviced</a>
        <a href="/sales" class="nav-link">🏡 Sales</a>
        <a href="/cart" class="nav-link cart-link">
          🛒 Cart <% if (cartCount > 0) { %><span class="cart-badge"><%= cartCount %></span><% } %>
        </a>
      </nav>
    </div>
  </header>

  <!-- Apartment Details -->
  <section class="apartment-details-section">
    <div class="container">
      <div class="apartment-details-container">
        <!-- Media Gallery -->
        <div class="apartment-gallery">
          <!-- Main Image Display -->
          <div class="main-media">
            <img id="mainImage" src="<%= apartment.image_url %>" alt="<%= apartment.title %>" class="main-image">
            <% if (apartment.video_url) { %>
            <div class="video-overlay" onclick="openVideoModal()">
              <div class="play-button">▶</div>
              <span class="video-badge">VIDEO</span>
            </div>
            <% } %>
          </div>

          <!-- Media Thumbnails -->
          <div class="gallery-thumbs">
            <!-- Image Thumbnail -->
            <div class="thumb-item active" onclick="changeMedia(this, '<%= apartment.image_url %>', 'image')">
              <img src="<%= apartment.image_url %>" alt="Photo" class="thumb">
              <span class="media-type">📷</span>
            </div>
            <!-- Video Thumbnail (if exists) -->
            <% if (apartment.video_url) { %>
            <div class="thumb-item" onclick="changeMedia(this, '<%= apartment.video_url %>', 'video')">
              <svg class="thumb-video" viewBox="0 0 100 100">
                <rect width="100" height="100" fill="#f0f0f0"/>
                <polygon points="35,25 35,75 75,50" fill="#17a2b8"/>
              </svg>
              <span class="media-type">🎬</span>
            </div>
            <% } %>
          </div>
        </div>

        <div class="apartment-details-info">
          <div class="details-header">
            <h1><%= apartment.title %></h1>
            <span class="category-badge"><%= apartment.category %></span>
          </div>

          <p class="location-large">📍 <%= apartment.location %></p>

          <div class="price-section">
            <h2 class="price-large">$<%= apartment.price.toLocaleString() %></h2>
            <p class="price-subtitle">
              <% if (apartment.category === 'Rent') { %>per month<% } else if (apartment.category === 'Serviced') { %>per night<% } else { %>asking price<% } %>
            </p>
            <% if (apartment.inventoryCount) { %>
            <div class="inventory-status">
              <span class="inventory-icon">✓</span>
              <span class="inventory-text"><%= apartment.inventoryCount %> unit<%= apartment.inventoryCount !== 1 ? 's' : '' %> available</span>
            </div>
            <% } %>
          </div>

          <div class="features-grid">
            <% if (apartment.bedrooms > 0) { %>
            <div class="feature">
              <span class="feature-icon">🛏️</span>
              <span class="feature-name">Bedrooms</span>
              <span class="feature-value"><%= apartment.bedrooms %></span>
            </div>
            <% } %>
            <div class="feature">
              <span class="feature-icon">🚿</span>
              <span class="feature-name">Bathrooms</span>
              <span class="feature-value"><%= apartment.bathrooms %></span>
            </div>
          </div>

          <div class="description-section">
            <h3>Description</h3>
            <p><%= apartment.description %></p>
          </div>

          <div class="amenities-section">
            <h3>Amenities & Features</h3>
            <div class="amenities-list">
              <% if (apartment.features) { 
                const features = apartment.features.split(',');
                features.forEach(feature => { %>
                <div class="amenity-item">✓ <%= feature.trim() %></div>
              <% });
              } %>
            </div>
          </div>

          <!-- Social Share Section -->
          <div class="share-section">
            <h3>📱 Share This Property</h3>
            <div class="share-buttons">
              <button class="share-btn facebook" onclick="shareToSocial('facebook')">
                <span>f</span> Facebook
              </button>
              <button class="share-btn twitter" onclick="shareToSocial('twitter')">
                <span>𝕏</span> Twitter
              </button>
              <button class="share-btn linkedin" onclick="shareToSocial('linkedin')">
                <span>in</span> LinkedIn
              </button>
              <button class="share-btn whatsapp" onclick="shareToSocial('whatsapp')">
                <span>💬</span> WhatsApp
              </button>
              <button class="share-btn telegram" onclick="shareToSocial('telegram')">
                <span>✈️</span> Telegram
              </button>
              <button class="share-btn pinterest" onclick="shareToSocial('pinterest')">
                <span>P</span> Pinterest
              </button>
              <button class="share-btn email" onclick="shareToSocial('email')">
                <span>✉️</span> Email
              </button>
              <button class="share-btn copy" onclick="shareToSocial('copy')">
                <span>📋</span> Copy Link
              </button>
            </div>
          </div>

          <div class="action-buttons">
            <button id="addToCartBtn" class="btn btn-primary" data-id="<%= apartment.id %>">
              🛒 Add to Cart
            </button>
            <button id="inquireBtn" class="btn btn-secondary">
              📧 Make Inquiry
            </button>
          </div>

          <div class="contact-info">
            <h3>Contact Information</h3>
            <p>📧 Email: info@andrewaps.com</p>
            <p>📞 Phone: +1 (555) 123-4567</p>
            <p>For inquiries about this property, please reach out to us.</p>
          </div>
        </div>
      </div>

      <div class="back-link">
        <a href="/<%= category.toLowerCase() %>">&larr; Back to <%= category %></a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-section">
        <h3>Andrew Apartments</h3>
        <p>Your trusted real estate partner for quality homes.</p>
      </div>
      <div class="footer-section">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/rent">Rent</a></li>
          <li><a href="/serviced">Serviced Apartments</a></li>
          <li><a href="/sales">Sales</a></li>
          <li><a href="/admin/dashboard">Admin</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4>Contact</h4>
        <p>📧 Email: info@andrewaps.com</p>
        <p>📞 Phone: +1 (555) 123-4567</p>
        <p>📍 Address: 123 Real Estate Ave, Your City</p>
      </div>
      <div class="footer-section">
        <h4>Follow Us</h4>
        <div class="social-links">
          <a href="#">Facebook</a>
          <a href="#">Twitter</a>
          <a href="#">Instagram</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Andrew Apartments. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
  <script>
    // Social Share URLs
    const shareUrls = {
      facebook: '<%=shareUrls.facebook%>',
      twitter: '<%=shareUrls.twitter%>',
      linkedin: '<%=shareUrls.linkedin%>',
      whatsapp: '<%=shareUrls.whatsapp%>',
      telegram: '<%=shareUrls.telegram%>',
      pinterest: '<%=shareUrls.pinterest%>',
      email: '<%=shareUrls.email%>',
      copy: '<%=shareUrls.copy%>'
    };

    // Share to Social Media Function
    function shareToSocial(platform) {
      if (platform === 'copy') {
        // Copy to clipboard
        const tempInput = document.createElement('input');
        tempInput.value = shareUrls.copy;
        document.body.appendChild(tempInput);
        tempInput.select();
        document.execCommand('copy');
        document.body.removeChild(tempInput);
        alert('✓ Link copied to clipboard!');
      } else if (shareUrls[platform]) {
        // Open social share in new window
        const width = 600;
        const height = 400;
        const left = (window.innerWidth - width) / 2;
        const top = (window.innerHeight - height) / 2;
        window.open(shareUrls[platform], 'share', `width=${width},height=${height},left=${left},top=${top}`);
      }
    }

    // Add to Cart
    document.getElementById('addToCartBtn').addEventListener('click', function() {
      const apartmentId = this.dataset.id;
      fetch('/cart/add/' + apartmentId, { method: 'POST' })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('✓ Added to cart!');
            location.reload();
          }
        });
    });

    // Inquiry Button
    document.getElementById('inquireBtn').addEventListener('click', function() {
      alert('Thank you for your interest! Our team will contact you soon.');
    });

    // === MEDIA GALLERY FUNCTIONS ===
    
    // Store current media state
    let currentMediaType = 'image';
    let currentVideoUrl = '<%= apartment.video_url || "" %>';

    // Change media display
    function changeMedia(element, url, type) {
      // Update active thumbnail
      document.querySelectorAll('.thumb-item').forEach(item => item.classList.remove('active'));
      element.classList.add('active');

      // Update main display
      const mainMedia = document.querySelector('.main-media');
      
      if (type === 'image') {
        document.getElementById('mainImage').src = url;
        document.getElementById('mainImage').style.display = 'block';
        const overlay = mainMedia.querySelector('.video-overlay');
        if (overlay) overlay.style.display = currentVideoUrl ? 'flex' : 'none';
        currentMediaType = 'image';
      } else if (type === 'video') {
        document.getElementById('mainImage').style.display = 'none';
        if (!mainMedia.querySelector('.video-overlay')) {
          const overlay = document.createElement('div');
          overlay.className = 'video-overlay';
          overlay.onclick = openVideoModal;
          overlay.innerHTML = '<div class="play-button">▶</div><span class="video-badge">VIDEO</span>';
          mainMedia.appendChild(overlay);
        }
        mainMedia.querySelector('.video-overlay').style.display = 'flex';
        currentMediaType = 'video';
      }
    }

    // Open video modal
    function openVideoModal() {
      if (!currentVideoUrl) return;
      
      const modal = document.getElementById('videoModal');
      const videoFrame = document.getElementById('videoFrame');
      
      // Extract YouTube video ID from URL
      const youtubeId = extractYouTubeId(currentVideoUrl);
      if (youtubeId) {
        videoFrame.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1`;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }
    }

    // Close video modal
    function closeVideoModal() {
      const modal = document.getElementById('videoModal');
      const videoFrame = document.getElementById('videoFrame');
      modal.style.display = 'none';
      videoFrame.src = ''; // Stop video playback
      document.body.style.overflow = 'auto';
    }

    // Extract YouTube video ID from various URL formats
    function extractYouTubeId(url) {
      if (!url) return null;
      
      // Format: https://youtube.com/watch?v=ID
      const match1 = url.match(/youtube\.com\/watch\?v=([^&]+)/);
      if (match1) return match1[1];
      
      // Format: https://youtu.be/ID
      const match2 = url.match(/youtu\.be\/([^?]+)/);
      if (match2) return match2[1];
      
      // Format: https://www.youtube.com/embed/ID
      const match3 = url.match(/embed\/([^?]+)/);
      if (match3) return match3[1];
      
      return null;
    }

    // Close modal on outside click
    document.addEventListener('DOMContentLoaded', function() {
      const modal = document.getElementById('videoModal');
      if (modal) {
        modal.addEventListener('click', function(e) {
          if (e.target === modal) {
            closeVideoModal();
          }
        });
      }
      
      // Close on Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          closeVideoModal();
        }
      });
    });
  </script>

  <!-- Video Modal -->
  <div id="videoModal" class="video-modal">
    <div class="video-modal-content">
      <button class="video-modal-close" onclick="closeVideoModal()">&times;</button>
      <iframe id="videoFrame" class="video-iframe" width="100%" height="100%" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
    </div>
  </div>
</body>
</html>
