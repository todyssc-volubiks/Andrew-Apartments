<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Andrew Apartments</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-container">
      <div class="logo">
        <a href="/" class="logo-link">
          <div class="logo-icon">
            <svg viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg" class="logo-svg">
              <!-- Building structure -->
              <rect x="8" y="15" width="34" height="28" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
              <!-- Roof -->
              <polygon points="21,15 25,5 29,15" fill="currentColor" opacity="0.8"/>
              <!-- Windows -->
              <rect x="12" y="20" width="5" height="5" fill="currentColor" opacity="0.6"/>
              <rect x="20" y="20" width="5" height="5" fill="currentColor" opacity="0.6"/>
              <rect x="28" y="20" width="5" height="5" fill="currentColor" opacity="0.6"/>
              <rect x="36" y="20" width="5" height="5" fill="currentColor" opacity="0.6"/>
              <rect x="12" y="30" width="5" height="5" fill="currentColor" opacity="0.6"/>
              <rect x="20" y="30" width="5" height="5" fill="currentColor" opacity="0.6"/>
              <rect x="28" y="30" width="5" height="5" fill="currentColor" opacity="0.6"/>
              <rect x="36" y="30" width="5" height="5" fill="currentColor" opacity="0.6"/>
              <!-- Door -->
              <rect x="22" y="38" width="6" height="8" fill="currentColor" opacity="0.7"/>
            </svg>
          </div>
          <span class="logo-text">ANDREW</span>
        </a>
      </div>
      <div class="search-bar">
        <form action="/search" method="GET">
          <input type="text" name="q" placeholder="Search apartments..." required>
          <select name="category">
            <option value="">All Categories</option>
            <option value="Rent">Rent</option>
            <option value="Serviced">Serviced</option>
            <option value="Sales">Sales</option>
          </select>
          <button type="submit">🔍 Search</button>
        </form>
      </div>
      <nav class="nav-menu" id="navMenu">
        <a href="/rent" class="nav-link">🏠 Rent</a>
        <a href="/serviced" class="nav-link">⭐ Serviced</a>
        <a href="/sales" class="nav-link">🏡 Sales</a>
        <a href="/cart" class="nav-link cart-link">
          🛒 Cart <% if (cartCount > 0) { %><span class="cart-badge"><%= cartCount %></span><% } %>
        </a>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </header>

  <!-- Main Content -->
  <main class="main-content">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-section">
        <h3>Andrew Apartments</h3>
        <p>Your trusted real estate partner for quality homes.</p>
      </div>
      <div class="footer-section">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/rent">Rent</a></li>
          <li><a href="/serviced">Serviced Apartments</a></li>
          <li><a href="/sales">Sales</a></li>
          <li><a href="/admin/dashboard">Admin</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4>Contact</h4>
        <p>📧 Email: info@andrewaps.com</p>
        <p>📞 Phone: +1 (555) 123-4567</p>
        <p>📍 Address: 123 Real Estate Ave, Your City</p>
      </div>
      <div class="footer-section">
        <h4>Follow Us</h4>
        <div class="social-links">
          <a href="#">Facebook</a>
          <a href="#">Twitter</a>
          <a href="#">Instagram</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Andrew Apartments. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
