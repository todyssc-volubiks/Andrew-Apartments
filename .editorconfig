# EditorConfig helps maintain consistent coding styles across different editors
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript, JSON
[*.{js,jsx,json,mjs}]
indent_style = space
indent_size = 2

# HTML, CSS, SCSS, LESS
[*.{html,css,scss,less}]
indent_style = space
indent_size = 2

# EJS templates
[*.ejs]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 4
end_of_line = lf

# Dockerfiles
[Dockerfile*]
indent_style = space
indent_size = 4
